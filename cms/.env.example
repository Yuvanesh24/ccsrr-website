# CMS Environment Variables
HOST=0.0.0.0
PORT=1337
APP_KEYS=tobemodifiedkey1,tobemodifiedkey2,tobemodifiedkey3,tobemodifiedkey4
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified

# Database - defaults to SQLite (no additional config needed)
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db

# For PostgreSQL (production), uncomment and configure:
# DATABASE_CLIENT=postgres
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_NAME=ccsrr_cms
# DATABASE_USERNAME=ccsrr
# DATABASE_PASSWORD=yourpassword
# DATABASE_SSL=true
